# Microsoft Fabric deployment workspace mappings (dotenv format)
#
# Resolution precedence used by scripts/deploy.py:
# 1) --workspace_name CLI argument
# 2) .env in current working directory
# 3) this deploy.config file (same folder as deploy.py)
# 4) fail if unresolved
#
# Format:
#   PBI_WORKSPACE_<ENV>=<Workspace Name>
#
# Examples:
#   PBI_WORKSPACE_DEV=Workshop - Lab 2 (DEV)
#   PBI_WORKSPACE_PRD=Workshop - Lab 2
#
# Notes:
# - Comment lines start with '#'.
# - Blank lines are allowed.
# - Environment suffix is matched uppercase (e.g., DEV, PRD).

PBI_WORKSPACE_PRD=Workshop - Lab 2
PBI_WORKSPACE_DEV=Workshop - Lab 2 (DEV)
